{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/racing-shop build",
  "outputDirectory": "artifacts/racing-shop/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://maxspeed-maxspeed-production.up.railway.app/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
